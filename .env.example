# Thời gian quét mặc định (giây)
SCAN_SECONDS=15

# Gợi ý tên cân (phân tách bằng dấu phẩy, không phân biệt hoa thường)
NAME_HINTS=Scale,SCALE,BLE,Weight,WEIGHT,JIN,Jinlyun,LYUN

# CORS cho React dev server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Parser khối lượng: uni_js_only (mặc định, công thức UNI) | auto (thử ffe_qn, generic…)
WEIGHT_PARSER=uni_js_only

# CLI nhanh: python connect_scale.py <MAC từ bảng quét>
